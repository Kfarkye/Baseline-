rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidPreferences(prefs) {
      return prefs is map &&
             prefs.keys().hasOnly(['favoriteLeagues', 'riskLevel']) &&
             prefs.favoriteLeagues is list &&
             prefs.riskLevel in ['low', 'medium', 'high'];
    }

    // Entity validations
    function isValidUser(data) {
      return data.keys().hasOnly([
               'userId',
               'email',
               'displayName',
               'balance',
               'planTier',
               'queryCount',
               'lastQueryDate',
               'preferences'
             ]) &&
             data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 120 &&
             data.balance is number && data.balance == 0 &&
             data.planTier == 'free' &&
             data.queryCount is number && data.queryCount == 0 &&
             data.lastQueryDate is string &&
             isValidPreferences(data.preferences);
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'role', 'timestamp']) &&
             data.keys().size() == 3 &&
             data.text is string && data.text.size() <= 500000 &&
             data.role in ['user', 'model'] &&
             data.timestamp is timestamp;
    }

    function isValidRecommendation(data) {
      return data.keys().hasAll(['matchName', 'odds', 'reasoning', 'prediction']) &&
             data.matchName is string && data.matchName.size() <= 500 &&
             data.odds is number &&
             data.reasoning is string && data.reasoning.size() <= 2000 &&
             data.prediction is string;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        // Action: Update Profile/Preferences
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'preferences']) &&
         incoming().displayName is string && incoming().displayName.size() <= 120 &&
         isValidPreferences(incoming().preferences)) ||
        // Action: Update Query Tracking
        (incoming().diff(existing()).affectedKeys().hasOnly(['queryCount', 'lastQueryDate']) &&
         incoming().queryCount is number &&
         incoming().queryCount >= 0 &&
         incoming().queryCount <= 1000000 &&
         incoming().lastQueryDate is string)
      );
    }

    // 2. Chat History (Subcollection of User)
    match /users/{userId}/chats/{chatId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidChatMessage(incoming());
    }

    // 3. Recommendations
    match /users/{userId}/recommendations/{recId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidRecommendation(incoming());
    }
    function isValidArtifact(data) {
      return data.keys().hasAll(['content', 'type', 'createdAt', 'creatorId', 'title', 'source', 'fetchedAt']) &&
             data.content is string && data.content.size() <= 1048576 &&
             data.type is string && data.type in ['html', 'python', 'markdown'] &&
             data.createdAt is timestamp &&
             data.creatorId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.source is string && data.source.size() <= 1024 &&
             data.fetchedAt is timestamp;
    }

    // 4. Artifacts (Owner-only read/write)
    match /artifacts/{artifactId} {
      allow get, list: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow create: if isSignedIn() &&
                    isValidArtifact(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().fetchedAt == request.time;
    }
  }
}
